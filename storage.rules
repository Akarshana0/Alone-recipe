// storage.rules
// Deploy with: firebase deploy --only storage

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Recipe media ───────────────────────────────────────────────
    match /recipes/{allPaths=**} {

      // PUBLIC: Anyone can read/view recipe media
      allow read: if true;

      // RESTRICTED: Only the admin can upload or delete
      allow write: if request.auth != null
                   && request.auth.token.email == 'pansiluakarshana0@gmail.com'
                   && (
                     // Allow images up to 10MB
                     (request.resource.contentType.matches('image/.*')
                       && request.resource.size <= 10 * 1024 * 1024)
                     ||
                     // Allow videos up to 100MB
                     (request.resource.contentType.matches('video/.*')
                       && request.resource.size <= 100 * 1024 * 1024)
                   );
    }

    // Block everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
