rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // ── Users ─────────────────────────────────────────────────
    // Users can read/update their OWN document.
    // Admins can read/write any user document.
    //
    // HWID RESET PROTECTION:
    //   A user can update their own document BUT they are NOT allowed to
    //   write arbitrary fields. Specifically, sensitive fields like `plan`,
    //   `licenseExpiry`, `role`, `activeDevices`, `maxDevices` can only be
    //   written by admins. The user can only update hwid (to null), display
    //   name, and HWID reset tracking fields.
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();

      allow create: if isOwner(uid);

      // User self-update: only allow safe fields
      // (hwid reset, displayName, sessionToken, photoURL)
      allow update: if isOwner(uid) && onlySafeUserFields() || isAdmin();

      allow delete: if isAdmin();
    }

    function onlySafeUserFields() {
      // Fields the user is allowed to change themselves
      let allowed = [
        "displayName",
        "photoURL",
        "sessionToken",
        "lastLoginAt",
        "hwid",                 // can be set to null (HWID reset)
        "hwidResetCount",
        "hwidResetHistory",
        "hwidLastResetAt",
        "devices",              // per-device session tracking (Device Management Panel)
      ];
      // Incoming request must only touch the allowed fields
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed);
    }

    // ── Packages (public read, admin write) ───────────────────
    match /packages/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Downloads ─────────────────────────────────────────────
    // Free (isPremium==false) files → public read (no login needed)
    // Premium (isPremium==true) files → logged-in users only
    // Write → admin only
    //
    // BUG FIX: Split into explicit get + list so Firestore's query evaluator
    // can verify non-auth list queries on free files are safe. A combined
    // `allow read` can be rejected for unauthenticated list queries when
    // Firebase can't statically prove `resource.data.isPremium == false`
    // holds for all documents in the result set.
    match /downloads/{id} {
      allow get:  if resource.data.isPremium == false || isAuth();
      allow list: if resource.data.isPremium == false || isAuth();
      allow write: if isAdmin();
    }

    // ── Orders ────────────────────────────────────────────────
    match /orders/{id} {
      allow read:   if isAdmin() || (isAuth() && resource.data.uid == request.auth.uid);
      allow create: if true;   // guests and logged-in users can both place orders
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Site Content (public read, admin write) ───────────────
    match /siteContent/{pageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Announcements (public read, admin write) ──────────────
    match /announcements/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── RegzAuth Verified Emails ───────────────────────────────
    // Written when a user successfully logs in via REX SOUTH.
    // Read during Firebase email login to verify the email is REX SOUTH registered.
    //
    // SECURITY NOTE: "create" is public because REX SOUTH sessions have no
    // Firebase token. "update/delete" is admin-only to prevent tampering.
    // Reads are restricted to authenticated users only.
    match /regzVerifiedEmails/{emailId} {
      allow read:   if isAuth();
      allow create: if true;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Tickets ────────────────────────────────────────────────
    // Users can create tickets and read/reply on their OWN tickets.
    // Admins can read/update any ticket.
    match /tickets/{id} {
      allow read:   if isAdmin() || (isAuth() && resource.data.uid == request.auth.uid);
      allow create: if isAuth();
      allow update: if isAdmin() || (isAuth() && resource.data.uid == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ── RegzAuth Users (HWID Reset Requests) ─────────────────
    // RegzAuth-only sessions have no Firebase Auth token, so rules use
    // `true` for create/update — rate limiting is enforced in the
    // resetRegzUserHWID() function (Firestore read before write).
    //
    // SECURITY: The worst a bad actor can do is flood Firestore with requests
    // under different usernames, but:
    //   1. Each write is bounded by the 3/day logic in the function.
    //   2. Only admins can mark requests as processed (pendingAdminReset=false).
    //   3. Actual HWID reset on RegzAuth server still requires admin action.
    //
    // Admin-only fields (pendingAdminReset=false, adminProcessedAt) are
    // protected by requiring isAdmin() for updates that touch them.
    match /rzUsers/{username} {
      allow read:   if true;          // user needs to read their own rate-limit info
      allow create: if true;          // first-time request (no Firebase token available)
      allow update: if true;          // subsequent requests (rate-limit enforced in code)
      allow delete: if isAdmin();
    }
  }
}
