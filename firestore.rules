// firestore.rules
// Deploy with: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Recipes collection ─────────────────────────────────────────
    match /recipes/{recipeId} {

      // PUBLIC: Anyone can READ recipes (no auth required)
      allow read: if true;

      // RESTRICTED: Only the specific admin can write (create/update/delete)
      allow write: if request.auth != null
                   && request.auth.token.email == 'pansiluakarshana0@gmail.com';
    }

    // Block everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
